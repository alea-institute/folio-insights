# folio-enrich path (required for bridge adapter)
FOLIO_ENRICH_PATH=~/Coding Projects/folio-enrich/backend
FOLIO_MAPPER_PATH=~/Coding Projects/folio-mapper/backend

# LLM configuration (provider agnostic)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
# Per-task overrides: LLM_BOUNDARY_PROVIDER, LLM_CLASSIFIER_PROVIDER, etc.

# Doctor microservice (optional, for WPD files)
DOCTOR_URL=http://localhost:5050

# Confidence thresholds
CONFIDENCE_HIGH=0.8
CONFIDENCE_MEDIUM=0.5
