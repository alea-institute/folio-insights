# Sibling-repo paths (required for bridge adapter)
# folio-insights imports services from folio-enrich and folio-mapper via
# a sys.path bridge. Clone both repos and point these at the backend dirs.
#   https://github.com/alea-institute/folio-enrich
#   https://github.com/alea-institute/folio-mapper
# Defaults (in config.py) assume they live as siblings of this repo.
FOLIO_INSIGHTS_FOLIO_ENRICH_PATH=../folio-enrich/backend
FOLIO_INSIGHTS_FOLIO_MAPPER_PATH=../folio-mapper/backend

# LLM configuration (provider agnostic)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
# Per-task overrides: LLM_BOUNDARY_PROVIDER, LLM_CLASSIFIER_PROVIDER, etc.

# Doctor microservice (optional, for WPD files)
DOCTOR_URL=http://localhost:5050

# Confidence thresholds
CONFIDENCE_HIGH=0.8
CONFIDENCE_MEDIUM=0.5
